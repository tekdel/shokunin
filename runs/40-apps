#!/bin/bash
# runs/apps - Optional applications

# Web browser
paru -S --needed --noconfirm --skipreview \
    google-chrome

# File manager and thumbnails
sudo pacman -S --needed --noconfirm \
    nautilus \
    file-roller \
    ffmpegthumbnailer

# Media
sudo pacman -S --needed --noconfirm \
    mpv \
    imv

# Screen recording (OBS Studio - full featured with webcam, audio, scenes)
sudo pacman -S --needed --noconfirm \
    obs-studio

# PDF viewer
sudo pacman -S --needed --noconfirm \
    zathura \
    zathura-pdf-mupdf

# Password manager
paru -S --needed --noconfirm --skipreview \
    1password

# Office (uncomment if needed)
# sudo pacman -S --needed --noconfirm \
#     libreoffice-fresh

# Development & Database
paru -S --needed --noconfirm --skipreview \
    dbeaver \
    visual-studio-code-bin

# Music & Entertainment
paru -S --needed --noconfirm --skipreview \
    spotify

# File sharing (AirDrop-like, works with phones)
paru -S --needed --noconfirm --skipreview \
    localsend-bin

# Communication (AUR - uncomment if needed)
# paru -S --needed --noconfirm --skipreview \
#     discord \
#     slack-desktop

echo "Applications installed successfully!"
