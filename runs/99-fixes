#!/bin/bash
# runs/99-fixes - Apply system fixes for existing installations
# Note: Most configuration is now handled by 00-essential and install/* scripts
# This script only contains fixes that might be needed on older systems

echo "Applying system fixes..."

# Enable multilib repository for 32-bit libraries (Steam, Wine, etc.)
if ! grep -q "^\[multilib\]" /etc/pacman.conf; then
    echo "Enabling multilib repository..."
    sudo sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' /etc/pacman.conf
    sudo pacman -Sy
    echo "✓ Multilib enabled"
fi

# Fix pacman keyring if corrupted
if ! pacman-key --list-keys &>/dev/null 2>&1; then
    echo "Fixing pacman keyring..."
    sudo rm -f /var/lib/pacman/db.lck
    sudo rm -rf /etc/pacman.d/gnupg
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    sudo pacman -Sy --noconfirm archlinux-keyring
    echo "✓ Keyring fixed"
fi

# Fix broken plymouth-encrypt if it was applied on older installations
if grep -q "plymouth-encrypt" /etc/mkinitcpio.conf 2>/dev/null; then
    echo "Fixing broken plymouth-encrypt (reverting to encrypt)..."
    sudo sed -i 's/plymouth-encrypt/encrypt/' /etc/mkinitcpio.conf
    sudo mkinitcpio -P
    echo "✓ Plymouth hooks fixed"
fi

# Fix rust/rustup conflict (rust package conflicts with rustup)
if pacman -Q rust &>/dev/null; then
    echo "Fixing rust/rustup conflict..."
    sudo pacman -R --noconfirm rust
    echo "✓ rust package removed"

    # Install rustup if not present
    if ! pacman -Q rustup &>/dev/null; then
        sudo pacman -S --needed --noconfirm rustup
        echo "✓ rustup installed"
    fi

    # Initialize rustup if needed
    if ! rustup show active-toolchain &>/dev/null; then
        rustup default stable
        echo "✓ Rust stable toolchain initialized"
    fi
fi

# Ensure user is in docker group if docker is installed
if command -v docker &>/dev/null && ! groups | grep -q docker; then
    echo "Adding user to docker group..."
    sudo usermod -aG docker "$USER"
    echo "✓ Added $USER to docker group (log out and back in to apply)"
fi

# Fix DNS configuration for systemd-resolved
# /etc/resolv.conf should be a symlink to systemd-resolved's stub resolver
if [ -f /etc/resolv.conf ] && [ ! -L /etc/resolv.conf ]; then
    echo "Fixing DNS configuration (systemd-resolved)..."
    echo "Creating symlink: /etc/resolv.conf -> /run/systemd/resolve/stub-resolv.conf"
    sudo cp /etc/resolv.conf /etc/resolv.conf.backup
    sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
    echo "✓ DNS configuration fixed (old config backed up to /etc/resolv.conf.backup)"
fi

# Set Chrome Canary as default browser (if installed)
if [ -f /usr/share/applications/google-chrome-canary.desktop ]; then
    echo "Setting Chrome Canary as default browser..."
    for mime in x-scheme-handler/http x-scheme-handler/https x-scheme-handler/chrome text/html application/xhtml+xml; do
        xdg-mime default google-chrome-canary.desktop "$mime"
    done
    echo "✓ Chrome Canary set as default browser"
fi

# NVIDIA fixes (only if NVIDIA GPU is present)
if lspci | grep -qi 'nvidia'; then
    # Configure NVIDIA for clean shutdown and suspend
    if [ ! -f /etc/modprobe.d/nvidia.conf ]; then
        echo "Configuring NVIDIA power management..."
        sudo tee /etc/modprobe.d/nvidia.conf > /dev/null << 'EOF'
options nvidia NVreg_PreserveVideoMemoryAllocations=0
EOF
        echo "✓ NVIDIA power management configured"
    fi

    # Enable nvidia-persistenced for faster shutdown
    sudo systemctl enable nvidia-persistenced 2>/dev/null || true

    # Remove NVIDIA modules from initramfs if present (conflicts with Plymouth)
    if grep -q "^MODULES=.*nvidia" /etc/mkinitcpio.conf 2>/dev/null; then
        echo "Removing NVIDIA modules from initramfs (conflicts with Plymouth)..."
        sudo sed -i 's/ nvidia nvidia_modeset nvidia_uvm nvidia_drm//' /etc/mkinitcpio.conf
        sudo mkinitcpio -P
        echo "✓ NVIDIA modules removed from initramfs"
    fi
fi

# Fix MediaTek MT79xx WiFi on AMD systems (IOMMU page fault prevents firmware upload)
if lspci | grep -qi 'mediatek.*mt79' && grep -qi 'amd' /proc/cpuinfo; then
    LIMINE_CONF=""
    if [ -f /boot/limine/limine.conf ]; then
        LIMINE_CONF="/boot/limine/limine.conf"
    elif [ -f /boot/EFI/BOOT/limine.conf ]; then
        LIMINE_CONF="/boot/EFI/BOOT/limine.conf"
    elif [ -f /boot/limine.conf ]; then
        LIMINE_CONF="/boot/limine.conf"
    fi

    if [ -n "$LIMINE_CONF" ]; then
        if grep -q 'iommu=soft' "$LIMINE_CONF"; then
            echo "Upgrading iommu=soft to iommu=pt for MediaTek WiFi on AMD..."
            sudo sed -i 's/iommu=soft/iommu=pt/g' "$LIMINE_CONF"
            echo "Updated iommu=soft -> iommu=pt in $LIMINE_CONF (reboot required)"
        elif ! grep -q 'iommu=pt' "$LIMINE_CONF"; then
            echo "Adding iommu=pt for MediaTek WiFi on AMD..."
            sudo sed -i 's/^\(    cmdline:.*\)/\1 iommu=pt/' "$LIMINE_CONF"
            echo "Added iommu=pt to $LIMINE_CONF (reboot required)"
        fi
    fi
fi

echo ""
echo "System fixes applied!"
