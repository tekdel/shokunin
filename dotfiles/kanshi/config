# Kanshi monitor profiles
# Run 'hyprctl monitors' to find your panel description

# KTC H27P3 5K monitor with laptop disabled
profile ktc-5k {
    output "Shenzhen KTC Technology Group H27P3*" mode 5120x2880 position 0,0 scale 2
    output eDP-1 disable
    exec notify-send -t 3000 "Monitor" "KTC 5K"
}

# LG UltraFine with laptop disabled
profile ultrafine {
    output "LG Electronics LG UltraFine 901NTDV6P994" mode 3840x2160 position 0,0 scale 1
    output eDP-1 disable
    exec notify-send -t 3000 "Monitor" "UltraFine"
}

# Framework 13 2.2K (laptop only)
profile framework {
    output "BOE 0x0BCA*" enable mode 2256x1504@60Hz position 0,0 scale 1
    exec notify-send -t 3000 "Monitor" "Framework Laptop"
}

# Lenovo ThinkPad Z13 Gen 1 (laptop only)
profile z13 {
    output "Lenovo Group Limited 0x41A6*" enable mode 1920x1200@60Hz position 0,0 scale 1
    exec notify-send -t 3000 "Monitor" "Z13 Laptop"
}

# Fallback for other laptops
profile laptop {
    output eDP-1 enable position 0,0
    exec notify-send -t 3000 "Monitor" "Laptop"
}
